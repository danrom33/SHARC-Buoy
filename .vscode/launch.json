{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Debug with OpenOCD (ST-Link)",
			"type": "cortex-debug",
			"request": "launch",
			"cwd": "${workspaceFolder}",
			"executable": "./build/SRC/MAIN.elf",
			"servertype": "openocd",
			"device": "STM32L4R5",
			"configFiles": [
				"interface/stlink-v2.cfg",
				"target/stm32l4x.cfg"
			],
			"runToEntryPoint": "main",
			"showDevDebugOutput": "raw",
			"svdFile": "STM32L4R5.svd",
		}
	]
}